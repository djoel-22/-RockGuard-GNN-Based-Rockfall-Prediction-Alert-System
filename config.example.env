# ============================================================
# RockGuard — Example Configuration
# Copy this file to config.env and fill in your credentials.
# NEVER commit config.env to version control.
# ============================================================

# Firebase Realtime Database
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_DB_URL=https://your-project-id-default-rtdb.firebaseio.com/
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Twilio Voice Alerts
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Alert Thresholds (optional overrides — defaults shown)
RISK_ALERT_THRESHOLD=0.75        # 0.0 to 1.0
ALERT_POLL_INTERVAL_SEC=10       # How often to check Firebase
